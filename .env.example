# eBay Browse API
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_MARKETPLACE_DEFAULT=EBAY_ES

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email digest
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
DIGEST_EMAIL_TO=

# Runtime
RADAR_ENV=production
RADAR_DB_PATH=./data/radar.sqlite
RADAR_LOG_LEVEL=INFO
